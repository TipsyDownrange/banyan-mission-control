# BanyanOS Mission Control — environment variable reference.
# Populate the real values in Vercel (Production + staging) and in your
# local .env.local file. Do not commit real secrets.

# Cost & Usage Live Tracking Phase 1 — Mac mini relay shared secret.
# Required by POST /api/cost/ingest. Generate a random 32+ character string;
# set the same value in the Kai relay's keychain so it can sign requests.
BANYAN_COST_INGEST_SECRET=replace-with-32-plus-char-random-string
