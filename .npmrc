# BAN-374 Scheduling Spine — accept peer-dep mismatches that npm's strict
# resolver flags but that don't cause runtime issues.
#
# Concrete case: gantt-task-react@0.3.9 declares peer dep react@^18, but it
# compiles and runs cleanly against this project's react@19.  npm 8+ ERESOLVE
# rejects the install without --legacy-peer-deps; Vercel's default install
# step runs plain `npm install`, so this file enables the flag globally for
# both CI and local installs to stay in sync.
#
# Reviewers: this is a recoverable knob, not a security relaxation.  Remove
# when gantt-task-react publishes a React 19 peer-dep release (or when we
# swap to a different Gantt library).
legacy-peer-deps=true
